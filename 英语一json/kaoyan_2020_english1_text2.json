  {
    "sentence_id": "s_009",
    "year": 2020,
    "exam_type": "英语一",
    "text_id": "Text 2",
    "original": "The success of Sci-Hub, which relies on researchers passing on copies they have themselves legally accessed, shows the legal ecosystem has lost legitimacy among its users and must be transformed so that it works for all participants.",
