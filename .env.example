DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-this-with-a-long-random-string"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_DISPLAY_NAME="System Admin"

# Sub2API / OpenAI-compatible API. Use the origin only, without /v1.
SUB2API_BASE_URL="https://your-sub2api-origin.example.com"
SUB2API_API_KEY="replace-with-sub2api-key"
SUB2API_MODEL="gpt-5.5"

# Optional fallback OpenAI-compatible API.
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-v4-flash"
AI_TIMEOUT_MS="30000"
